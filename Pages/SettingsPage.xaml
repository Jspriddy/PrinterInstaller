<Page x:Class="HPPrinterScanner.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">

    <StackPanel Margin="16" MaxWidth="560" HorizontalAlignment="Left">

        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 16" />

        <!-- Network card -->
        <ui:CardExpander IsExpanded="False" Margin="0 0 0 12">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock Text="Network" FontWeight="SemiBold" />
                    <TextBlock Text="Subnet used when scanning for printers"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardExpander.Header>

            <StackPanel Margin="0 8 0 0">
                <!-- Auto-detect read-only display -->
                <Grid Margin="0 0 0 12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Auto-detected subnet" FontWeight="Medium" />
                        <TextBlock x:Name="AutoSubnetLabel" Opacity="0.6" FontSize="12" />
                    </StackPanel>
                </Grid>

                <!-- Override toggle -->
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Override subnet" FontWeight="Medium" />
                        <TextBlock Text="Enter a custom x.x.x prefix instead of auto-detect"
                                   Opacity="0.6" FontSize="12" />
                    </StackPanel>
                    <ui:ToggleSwitch x:Name="OverrideToggle" Grid.Column="1"
                                     Click="OverrideToggle_Toggled" />
                </Grid>

                <!-- Override input (visible only when toggled on) -->
                <ui:TextBox x:Name="SubnetOverrideBox"
                            PlaceholderText="e.g. 192.168.1"
                            Margin="0 0 0 12"
                            Visibility="Collapsed"
                            TextChanged="SubnetOverrideBox_TextChanged" />
            </StackPanel>
        </ui:CardExpander>

        <!-- Columns card -->
        <ui:CardExpander IsExpanded="False" Margin="0 0 0 12">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock Text="Columns" FontWeight="SemiBold" />
                    <TextBlock Text="Choose which columns appear in the scan results"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardExpander.Header>

            <StackPanel Margin="0 8 0 0">
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="MAC Address" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColMacToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Hostname" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColHostnameToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Model" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColModelToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Ports" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColPortsToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <!-- Manage Printers columns card -->
        <ui:CardExpander IsExpanded="False" Margin="0 0 0 12">
            <ui:CardExpander.Header>
                <StackPanel>
                    <TextBlock Text="Manage Printers Columns" FontWeight="SemiBold" />
                    <TextBlock Text="Choose which columns appear in the manage printers view"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardExpander.Header>

            <StackPanel Margin="0 8 0 0">
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Active Jobs" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColActiveJobsToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Port Type" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColPortTypeToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="IP / Host" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColIpHostToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
                <Grid Margin="0 0 0 8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Port" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColPortToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Driver" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColDriverToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </StackPanel>
        </ui:CardExpander>

        <StackPanel Orientation="Horizontal">
            <ui:Button Content="Save" Appearance="Primary" Click="SaveButton_Click" Margin="0 0 12 0" />
            <TextBlock x:Name="SaveStatus" VerticalAlignment="Center" Opacity="0.7" />
        </StackPanel>

    </StackPanel>
</Page>
