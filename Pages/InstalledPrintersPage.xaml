<Page x:Class="HPPrinterScanner.Pages.InstalledPrintersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Installed Printers">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="0 0 0 12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Manage Printers"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <ui:Button x:Name="RefreshButton" Grid.Column="1"
                       Content="Refresh" Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                       Appearance="Secondary"
                       Click="RefreshButton_Click" />
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar" Grid.Row="1"
                     IsIndeterminate="True" Height="4"
                     Margin="0 0 0 8"
                     Visibility="Collapsed" />

        <!-- Content area -->
        <Grid Grid.Row="2">

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Print24" FontSize="48"
                               HorizontalAlignment="Center" Margin="0 0 0 12" />
                <TextBlock Text="No printers found"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="No printers are installed on this machine."
                           Opacity="0.6" HorizontalAlignment="Center" Margin="0 4 0 0" />
            </StackPanel>

            <!-- Printers grid -->
            <DataGrid x:Name="PrintersGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      CanUserSortColumns="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      ColumnHeaderStyle="{StaticResource HoverColumnHeaderStyle}"
                      SelectionChanged="PrintersGrid_SelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        <EventSetter Event="PreviewMouseRightButtonDown"
                                     Handler="PrintersRow_PreviewMouseRightButtonDown" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Set as Default"
                                  Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                                  Click="SetDefaultButton_Click" />
                        <MenuItem Header="Clear Print Jobs"
                                  Icon="{ui:SymbolIcon Symbol=DismissCircle24}"
                                  Click="ClearJobsButton_Click" />
                        <Separator />
                        <MenuItem Header="Printer Properties"
                                  Icon="{ui:SymbolIcon Symbol=Info24}"
                                  Click="PropertiesButton_Click" />
                        <MenuItem Header="Printer Preferences"
                                  Icon="{ui:SymbolIcon Symbol=Options24}"
                                  Click="PreferencesButton_Click" />
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Printer Name" Width="*" MinWidth="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="2 0">
                                    <Ellipse x:Name="dot"
                                             Width="10" Height="10"
                                             Fill="#6B7280"
                                             VerticalAlignment="Center"
                                             Margin="0 0 8 0"
                                             ToolTip="{Binding StatusTooltip}" />
                                    <TextBlock Text="{Binding NameLabel}" VerticalAlignment="Center" />
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Online">
                                        <Setter TargetName="dot" Property="Fill" Value="#22C55E" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Offline">
                                        <Setter TargetName="dot" Property="Fill" Value="#EF4444" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Sleeping">
                                        <Setter TargetName="dot" Property="Fill" Value="#EAB308" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Error">
                                        <Setter TargetName="dot" Property="Fill" Value="#F97316" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Printing">
                                        <Setter TargetName="dot" Property="Fill" Value="#3B82F6" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Active Jobs"   Binding="{Binding ActiveJobsLabel}" Width="90" />
                    <DataGridTemplateColumn Header="Port Type" Width="110">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Port Type" VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Margin="4 0 0 0"
                                            Style="{StaticResource FilterDropdownButtonStyle}"
                                            Click="PortTypeFilterButton_Click">
                                        <TextBlock Text="▾" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PortTypeLabel}" Margin="2 0" VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="IP / Host"     Binding="{Binding IpAddress}"       Width="130" />
                    <DataGridTextColumn Header="Port"          Binding="{Binding PortName}"        Width="160" />
                    <DataGridTextColumn Header="Driver"        Binding="{Binding DriverName}"      Width="200" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Port type filter popup -->
        <Popup x:Name="PortTypeFilterPopup"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               Placement="Bottom"
               VerticalOffset="2">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    MinWidth="150"
                    Padding="4 6">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5" Color="Black" />
                </Border.Effect>
                <StackPanel>
                    <CheckBox x:Name="FilterCheckAll"   Content="All printers" IsChecked="True"
                              Margin="8 4"
                              Checked="FilterCheckAll_CheckedChanged"
                              Unchecked="FilterCheckAll_CheckedChanged" />
                    <Separator Margin="4 4" />
                    <CheckBox x:Name="FilterCheckTcpIp" Content="TCP/IP" IsChecked="True"
                              Margin="8 4"
                              Checked="FilterCheck_Changed"
                              Unchecked="FilterCheck_Changed" />
                    <CheckBox x:Name="FilterCheckIpp"   Content="IPP"   IsChecked="True"
                              Margin="8 4"
                              Checked="FilterCheck_Changed"
                              Unchecked="FilterCheck_Changed" />
                    <CheckBox x:Name="FilterCheckWsd"   Content="WSD"   IsChecked="True"
                              Margin="8 4"
                              Checked="FilterCheck_Changed"
                              Unchecked="FilterCheck_Changed" />
                    <CheckBox x:Name="FilterCheckLocal" Content="Local" IsChecked="True"
                              Margin="8 4"
                              Checked="FilterCheck_Changed"
                              Unchecked="FilterCheck_Changed" />
                </StackPanel>
            </Border>
        </Popup>

        <!-- Bottom action bar -->
        <Border Grid.Row="3" Margin="-16 8 -16 -16" Padding="16 10"
                BorderThickness="0 1 0 0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Centre: job scan diagnostics -->
                <TextBlock x:Name="JobDiagLabel" Grid.Column="1"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="12 0" FontSize="11" Opacity="0.6"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />

                <!-- Left: global spooler action -->
                <ui:Button x:Name="RestartSpoolerButton" Grid.Column="0"
                           Content="Restart Print Spooler" Icon="{ui:SymbolIcon Symbol=ArrowSync24}"
                           Appearance="Secondary"
                           Click="RestartSpoolerButton_Click" />

                <!-- Right: per-printer actions -->
                <ui:Button x:Name="RemoveButton" Grid.Column="2"
                           Content="Remove" Icon="{ui:SymbolIcon Symbol=Delete24}"
                           Appearance="Danger"
                           IsEnabled="False"
                           Click="RemoveButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Page>
