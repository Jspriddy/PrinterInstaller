<Page x:Class="HPPrinterScanner.Pages.ColumnsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Columns">

    <Page.Resources>
        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="16 14" />
            <Setter Property="Margin"          Value="0 0 0 4" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0 16" MaxWidth="700" HorizontalAlignment="Center">

            <!-- Breadcrumb + title + description -->
            <StackPanel Margin="0 0 0 20">
                <TextBlock FontSize="12" Margin="0 0 0 2">
                    <Hyperlink Click="Back_Click" TextDecorations="{x:Null}"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">Settings</Hyperlink>
                    <Run Text=" ›" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </TextBlock>
                <TextBlock Text="Columns" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 6" />
                <TextBlock Text="Choose which columns appear in each view"
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Section: Scan Results -->
            <TextBlock Text="SCAN RESULTS" FontSize="11" FontWeight="SemiBold" Margin="4 0 0 8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="MAC Address" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColMacToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Hostname" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColHostnameToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Model" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColModelToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Ports" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ColPortsToggle" Grid.Column="1" Click="ColToggle_Changed" />
                </Grid>
            </Border>

            <!-- Section: Manage Printers -->
            <TextBlock Text="MANAGE PRINTERS" FontSize="11" FontWeight="SemiBold" Margin="4 20 0 8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Active Jobs" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColActiveJobsToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Port Type" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColPortTypeToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="IP / Host" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColIpHostToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Port" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColPortToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </Border>
            <Border Style="{StaticResource SettingRowStyle}">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <TextBlock Text="Driver" FontWeight="Medium" VerticalAlignment="Center" />
                    <ui:ToggleSwitch x:Name="ManageColDriverToggle" Grid.Column="1" Click="ManageColToggle_Changed" />
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
