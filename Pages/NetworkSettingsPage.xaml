<Page x:Class="HPPrinterScanner.Pages.NetworkSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Network">

    <Page.Resources>
        <Style x:Key="SettingRowStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="16 14" />
            <Setter Property="Margin"          Value="0 0 0 4" />
        </Style>
    </Page.Resources>

    <StackPanel Margin="0 16" MaxWidth="700" HorizontalAlignment="Center">

        <!-- Breadcrumb + title + description -->
        <StackPanel Margin="0 0 0 20">
            <TextBlock FontSize="12" Margin="0 0 0 2">
                <Hyperlink Click="Back_Click" TextDecorations="{x:Null}"
                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">Settings</Hyperlink>
                <Run Text=" ›" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </TextBlock>
            <TextBlock Text="Network" FontSize="20" FontWeight="SemiBold" Margin="0 0 0 6" />
            <TextBlock Text="Subnet used when scanning for printers"
                       FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Auto-detected subnet (read-only info row) -->
        <Border Style="{StaticResource SettingRowStyle}">
            <StackPanel>
                <TextBlock Text="Auto-detected subnet" FontWeight="Medium" />
                <TextBlock x:Name="AutoSubnetLabel" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Override toggle -->
        <Border Style="{StaticResource SettingRowStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Override subnet" FontWeight="Medium" />
                    <TextBlock Text="Enter a custom x.x.x prefix instead of auto-detect"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:ToggleSwitch x:Name="OverrideToggle" Grid.Column="1"
                                 Click="OverrideToggle_Click" />
            </Grid>
        </Border>

        <!-- Custom subnet input (visible when override is on) -->
        <ui:TextBox x:Name="SubnetOverrideBox"
                    PlaceholderText="e.g. 192.168.1"
                    Margin="0 0 0 4"
                    Visibility="Collapsed"
                    LostFocus="SubnetBox_LostFocus" />

    </StackPanel>
</Page>
