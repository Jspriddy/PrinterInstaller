<ui:FluentWindow x:Class="HPPrinterScanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="HP Printer Scanner" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0" Title="HP Printer Scanner"
                     ShowMinimize="True" ShowMaximize="True" ShowClose="True" />

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Navigation -->
            <ui:NavigationView x:Name="NavView"
                               Grid.Column="0"
                               PaneDisplayMode="Left"
                               IsBackButtonVisible="Collapsed"
                               IsPaneToggleVisible="False">
                <ui:NavigationView.MenuItems>
                    <ui:NavigationViewItem x:Name="NavScan"
                                          Content="Install a Printer"
                                          Icon="{ui:SymbolIcon Symbol=Search24}"
                                          PreviewMouseLeftButtonDown="NavScan_Click" />
                    <ui:NavigationViewItem x:Name="NavInstalled"
                                          Content="Manage Printers"
                                          Icon="{ui:SymbolIcon Symbol=Print24}"
                                          PreviewMouseLeftButtonDown="NavInstalled_Click" />
                </ui:NavigationView.MenuItems>
                <ui:NavigationView.FooterMenuItems>
                    <ui:NavigationViewItem x:Name="NavSettings"
                                          Content="Settings"
                                          Icon="{ui:SymbolIcon Symbol=Settings24}"
                                          PreviewMouseLeftButtonDown="NavSettings_Click" />
                </ui:NavigationView.FooterMenuItems>
            </ui:NavigationView>

            <!-- Page frame -->
            <Frame x:Name="PageFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden" />
        </Grid>

        <!-- Status bar -->
        <ui:InfoBar x:Name="StatusBar"
                    Grid.Row="2"
                    IsOpen="True"
                    IsClosable="False"
                    Severity="Informational"
                    Title="Ready"
                    Message="Select an action from the left panel." />
    </Grid>
</ui:FluentWindow>
